				"assets_filename": "Assets.zip"
			},
			"latest_pre_release":{
				"scrape_assets": [false, true],
				"assets_path": "user://",
				"assets_filename": "Assets.zip"
			}
		},
		"release":{
			"previous_release":{
				"scrape_assets": [false, false],
				"assets_path": "user://",
